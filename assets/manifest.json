{
    "display_information": {
        "name": "slack-emoji-tracker"
    },
    "features": {
        "bot_user": {
            "display_name": "slack-emoji-tracker",
            "always_online": false
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "emoji:read",
                "chat:write"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "org_deploy_enabled": false,
        "socket_mode_enabled": false,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}
